<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thai Consonant Drill</title>
    <style>
        :root {
            --primary-color: #2563eb;
            --bg-color: #f3f4f6;
            --card-bg: #ffffff;
            --text-color: #1f2937;
            --success-color: #10b981;
            --error-color: #ef4444;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
        }

        .container {
            background-color: var(--card-bg);
            padding: 2rem;
            border-radius: 1rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            max-width: 500px;
            width: 100%;
            text-align: center;
            position: relative;
        }

        /* Screen visibility */
        .hidden {
            display: none !important;
        }

        /* --- Start Screen Styles --- */
        #start-screen {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 2rem 0;
        }

        #start-screen h1 {
            color: var(--primary-color);
            margin-bottom: 0.5rem;
            font-size: 1.8rem;
        }

        #start-screen p {
            color: #6b7280;
            margin-bottom: 2rem;
        }

        .name-input {
            width: 80%;
            padding: 0.75rem;
            border: 2px solid #e5e7eb;
            border-radius: 0.5rem;
            font-size: 1rem;
            margin-bottom: 1.5rem;
            text-align: center;
            outline: none;
            transition: border-color 0.2s;
        }

        .name-input:focus {
            border-color: var(--primary-color);
        }

        .start-btn {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 1rem 2rem;
            font-size: 1.2rem;
            border-radius: 0.5rem;
            cursor: pointer;
            font-weight: bold;
            transition: background-color 0.2s;
            width: 80%;
        }

        .start-btn:hover {
            background-color: #1d4ed8;
        }

        /* --- Quiz Screen Styles --- */
        header {
            margin-bottom: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .quiz-title {
            margin: 0;
            font-size: 1.5rem;
            color: var(--primary-color);
        }

        .top-bar {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            background: #f8fafc;
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            margin-top: 0.5rem;
        }

        .player-info {
            font-weight: bold;
            color: var(--primary-color);
            font-size: 1.1rem;
            border-bottom: 1px solid #e5e7eb;
            padding-bottom: 0.5rem;
        }

        .stats-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .hearts {
            font-size: 1.2rem;
            letter-spacing: 3px;
        }

        .score-box {
            font-weight: bold;
            color: #4b5563;
        }

        /* Flashcard Area */
        .character-display {
            font-size: 8rem;
            font-weight: bold;
            margin: 1rem 0;
            height: 160px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Sarabun', 'Thonburi', sans-serif; 
        }

        .question-text {
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
            color: #4b5563;
        }

        /* Options Grid */
        .options-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .option-btn {
            background-color: white;
            border: 2px solid #e5e7eb;
            border-radius: 0.5rem;
            padding: 1rem;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.2s;
            color: var(--text-color);
        }

        .option-btn:hover {
            border-color: var(--primary-color);
            background-color: #eff6ff;
        }

        .option-btn.correct {
            background-color: var(--success-color) !important;
            color: white !important;
            border-color: var(--success-color) !important;
        }

        .option-btn.wrong {
            background-color: var(--error-color) !important;
            color: white !important;
            border-color: var(--error-color) !important;
        }

        .feedback-msg {
            height: 1.5rem;
            margin-top: 1rem;
            font-weight: bold;
        }
        
        .feedback-correct { color: var(--success-color); }
        .feedback-wrong { color: var(--error-color); }

        /* Game Over Modal */
        .modal-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.95);
            border-radius: 1rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }

        .modal-content h2 {
            color: var(--error-color);
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .modal-content p {
            font-size: 1.2rem;
            margin-bottom: 2rem;
        }

        .modal-buttons {
            display: flex;
            gap: 10px;
        }

        .action-btn {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 10px 20px;
            font-size: 1rem;
            border-radius: 0.5rem;
            cursor: pointer;
        }

        .action-btn.secondary {
            background-color: #6b7280;
        }

        .action-btn:hover { opacity: 0.9; }

        @media (max-width: 400px) {
            .options-grid { grid-template-columns: 1fr; }
            .character-display { font-size: 6rem; }
        }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="container">
        
        <div id="start-screen">
            <h1>Thai Consonant Drill</h1>
            <p>Test your knowledge of the Thai alphabet!</p>
            <input type="text" id="player-name-input" class="name-input" placeholder="Enter your nickname" autocomplete="off">
            <button class="start-btn" onclick="startQuiz()">Start Quiz</button>
        </div>

        <div id="quiz-screen" class="hidden">
            
            <div id="game-over-modal" class="modal-overlay hidden">
                <div class="modal-content">
                    <h2>Game Over!</h2>
                    <p><span id="final-player-name"></span>, your final score is: <strong id="final-score">0</strong></p>
                    <div class="modal-buttons">
                        <button class="action-btn" onclick="restartGame()">Play Again</button>
                        <button class="action-btn secondary" onclick="goToStart()">Change Name</button>
                    </div>
                </div>
            </div>

            <header>
                <h2 class="quiz-title">Thai Consonant Drill</h2>
                <div class="top-bar">
                    <div class="player-info" id="display-name">Player</div>
                    <div class="stats-row">
                        <div class="hearts" id="hearts-display">❤️❤️❤️</div>
                        <div class="score-box" id="score">Score: 0</div>
                    </div>
                </div>
            </header>

            <div class="character-display" id="char-display">?</div>
            <p class="question-text">Select the correct name:</p>
            <div class="options-grid" id="options-container"></div>
            <div class="feedback-msg" id="feedback"></div>

        </div>

    </div>

    <script>
        const consonants = [
            { char: "ก", name: "Ko Kai", meaning: "Chicken" },
            { char: "ข", name: "Kho Khai", meaning: "Egg" },
            { char: "ฃ", name: "Kho Khuat", meaning: "Bottle" },
            { char: "ค", name: "Kho Khwai", meaning: "Buffalo" },
            { char: "ฅ", name: "Kho Khon", meaning: "Person" },
            { char: "ฆ", name: "Kho Rakhang", meaning: "Bell" },
            { char: "ง", name: "Ngo Ngu", meaning: "Snake" },
            { char: "จ", name: "Cho Chan", meaning: "Plate" },
            { char: "ฉ", name: "Cho Ching", meaning: "Cymbals" },
            { char: "ช", name: "Cho Chang", meaning: "Elephant" },
            { char: "ซ", name: "So So", meaning: "Chain" },
            { char: "ฌ", name: "Cho Choe", meaning: "Tree" },
            { char: "ญ", name: "Yo Ying", meaning: "Woman" },
            { char: "ฎ", name: "Do Chada", meaning: "Headdress" },
            { char: "ฏ", name: "To Patak", meaning: "Goad/Spear" },
            { char: "ฐ", name: "Tho Than", meaning: "Pedestal" },
            { char: "ฑ", name: "Tho Montho", meaning: "Montho" },
            { char: "ฒ", name: "Tho Phuthao", meaning: "Elder" },
            { char: "ณ", name: "No Nen", meaning: "Novice Monk" },
            { char: "ด", name: "Do Dek", meaning: "Child" },
            { char: "ต", name: "To Tao", meaning: "Turtle" },
            { char: "ถ", name: "Tho Thung", meaning: "Sack" },
            { char: "ท", name: "Tho Thahan", meaning: "Soldier" },
            { char: "ธ", name: "Tho Thong", meaning: "Flag" },
            { char: "น", name: "No Nu", meaning: "Mouse" },
            { char: "บ", name: "Bo Baimai", meaning: "Leaf" },
            { char: "ป", name: "Po Pla", meaning: "Fish" },
            { char: "ผ", name: "Pho Phueng", meaning: "Bee" },
            { char: "ฝ", name: "Fo Fa", meaning: "Lid" },
            { char: "พ", name: "Pho Phan", meaning: "Tray" },
            { char: "ฟ", name: "Fo Fan", meaning: "Teeth" },
            { char: "ภ", name: "Pho Samphao", meaning: "Sailboat" },
            { char: "ม", name: "Mo Ma", meaning: "Horse" },
            { char: "ย", name: "Yo Yak", meaning: "Giant" },
            { char: "ร", name: "Ro Ruea", meaning: "Boat" },
            { char: "ล", name: "Lo Ling", meaning: "Monkey" },
            { char: "ว", name: "Wo Waen", meaning: "Ring" },
            { char: "ศ", name: "So Sala", meaning: "Pavilion" },
            { char: "ษ", name: "So Ruesi", meaning: "Hermit" },
            { char: "ส", name: "So Suea", meaning: "Tiger" },
            { char: "ห", name: "Ho Hip", meaning: "Chest/Box" },
            { char: "ฬ", name: "Lo Chula", meaning: "Kite" },
            { char: "อ", name: "O Ang", meaning: "Basin" },
            { char: "ฮ", name: "Ho Nokhuk", meaning: "Owl" }
        ];

        let currentItem = null;
        let score = 0;
        let lives = 3;
        let isAnswering = true;
        let playerName = "Player";

        // DOM Elements
        const startScreen = document.getElementById('start-screen');
        const quizScreen = document.getElementById('quiz-screen');
        const nameInput = document.getElementById('player-name-input');
        const displayName = document.getElementById('display-name');
        
        const charDisplay = document.getElementById('char-display');
        const optionsContainer = document.getElementById('options-container');
        const scoreDisplay = document.getElementById('score');
        const heartsDisplay = document.getElementById('hearts-display');
        const feedbackDisplay = document.getElementById('feedback');
        
        const modal = document.getElementById('game-over-modal');
        const finalScoreSpan = document.getElementById('final-score');
        const finalPlayerName = document.getElementById('final-player-name');

        // Allow pressing Enter to start the quiz
        nameInput.addEventListener("keypress", function(event) {
            if (event.key === "Enter") {
                event.preventDefault();
                startQuiz();
            }
        });
// Update this URL to match your actual Render deployment!
        const BACKEND_URL = "https://YOURSITE-service.onrender.com";

        async function startQuiz() {
            // Get name or use default
            const inputVal = nameInput.value.trim();
            playerName = inputVal !== "" ? inputVal : "Anonymous Student";
            
            // Show a loading state while we fetch the streak
            startScreen.querySelector('.start-btn').textContent = "Loading...";
            startScreen.querySelector('.start-btn').disabled = true;

            try {
                // Call the backend to increment and get the streak
                const response = await fetch(`${BACKEND_URL}/start-quiz`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ nickname: playerName })
                });

                if (response.ok) {
                    const data = await response.json();
                    // Display name + streak (e.g., "Player 🔥 5 Starts")
                    displayName.textContent = `${playerName} 🔥 ${data.streak_count} Starts`;
                } else {
                    // Fallback if DB fails
                    displayName.textContent = playerName;
                    console.error("Backend error:", response.status);
                }
            } catch (error) {
                // Fallback if backend is asleep/offline
                displayName.textContent = playerName;
                console.error("Failed to connect to backend:", error);
            }

            // Reset button state
            startScreen.querySelector('.start-btn').textContent = "Start Quiz";
            startScreen.querySelector('.start-btn').disabled = false;

            // Switch screens
            startScreen.classList.add('hidden');
            quizScreen.classList.remove('hidden');
            
            restartGame();
        }
        function startQuiz() {
            // Get name or use default
            const inputVal = nameInput.value.trim();
            playerName = inputVal !== "" ? inputVal : "Anonymous Student";
            
            // Update UI with name
            displayName.textContent = playerName;
            
            // Switch screens
            startScreen.classList.add('hidden');
            quizScreen.classList.remove('hidden');
            
            restartGame();
        }

        function goToStart() {
            modal.classList.add('hidden');
            quizScreen.classList.add('hidden');
            startScreen.classList.remove('hidden');
            nameInput.value = ""; // Clear input for a new name
            nameInput.focus();
        }

        function getRandomInt(max) {
            return Math.floor(Math.random() * max);
        }

        function shuffleArray(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
        }

        function updateHearts() {
            let heartString = "";
            for(let i=0; i<lives; i++) heartString += "❤️";
            for(let i=lives; i<3; i++) heartString += "🖤";
            heartsDisplay.textContent = heartString;
        }

        function restartGame() {
            score = 0;
            lives = 3;
            scoreDisplay.textContent = `Score: 0`;
            updateHearts();
            modal.classList.add('hidden');
            generateQuestion();
        }

        function generateQuestion() {
            isAnswering = true;
            feedbackDisplay.textContent = "";
            feedbackDisplay.className = "feedback-msg";
            optionsContainer.innerHTML = "";

            const correctIndex = getRandomInt(consonants.length);
            currentItem = consonants[correctIndex];

            // Generate 3 Distractors
            let options = [currentItem];
            while (options.length < 4) {
                let randomDistractor = consonants[getRandomInt(consonants.length)];
                if (!options.includes(randomDistractor)) {
                    options.push(randomDistractor);
                }
            }
            shuffleArray(options);

            // Update UI
            charDisplay.textContent = currentItem.char;

            options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                btn.textContent = `${opt.name} (${opt.meaning})`;
                btn.onclick = () => checkAnswer(opt, btn);
                optionsContainer.appendChild(btn);
            });
        }

        function checkAnswer(selected, btnElement) {
            if (!isAnswering) return;
            isAnswering = false;

            const buttons = optionsContainer.querySelectorAll('button');

            if (selected.char === currentItem.char) {
                // Correct
                score++;
                btnElement.classList.add('correct');
                feedbackDisplay.textContent = "Correct!";
                feedbackDisplay.classList.add('feedback-correct');
                scoreDisplay.textContent = `Score: ${score}`;
                
                setTimeout(() => generateQuestion(), 1000);

            } else {
                // Wrong
                lives--;
                updateHearts();
                
                btnElement.classList.add('wrong');
                feedbackDisplay.textContent = `Wrong! It was ${currentItem.name}`;
                feedbackDisplay.classList.add('feedback-wrong');

                // Highlight correct answer
                buttons.forEach(b => {
                    if (b.textContent.includes(currentItem.name)) {
                        b.classList.add('correct');
                    }
                });

                if (lives <= 0) {
                    // Game Over
                    setTimeout(() => {
                        finalScoreSpan.textContent = score;
                        finalPlayerName.textContent = playerName;
                        modal.classList.remove('hidden');
                    }, 1000);
                } else {
                    // Continue
                    setTimeout(() => generateQuestion(), 1500);
                }
            }
        }
    </script>
</body>
</html>

